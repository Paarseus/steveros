<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="test_single_motor">
  <xacro:arg name="motor_id" default="21"/>
  <xacro:arg name="motor_type" default="RS03"/>
  <xacro:arg name="can_interface" default="can0"/>

  <link name="base_link"/>

  <joint name="test_joint" type="revolute">
    <parent link="base_link"/>
    <child link="motor_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" velocity="20.0" effort="60.0"/>
  </joint>

  <link name="motor_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.05"/></geometry>
    </visual>
  </link>

  <ros2_control name="test_motor" type="system">
    <hardware>
      <plugin>steveros_hardware/SteveROSHardware</plugin>
      <param name="can_interface">$(arg can_interface)</param>
      <param name="feedback_timeout">0.5</param>
      <param name="kp_ramp_duration">2.0</param>
    </hardware>

    <joint name="test_joint">
      <param name="motor_id">$(arg motor_id)</param>
      <param name="motor_type">$(arg motor_type)</param>
      <param name="sign">1</param>
      <param name="zero_offset_deg">0</param>
      <param name="kp">200.0</param>
      <param name="kd">5.0</param>
      <command_interface name="position">
        <param name="min">-6.28</param>
        <param name="max">6.28</param>
      </command_interface>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
</robot>
