<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="steveros">

  <!-- Cylinder geometry for all links (replace with K-Scale STL meshes later) -->
  <xacro:macro name="arm_link" params="name length:=0.1 radius:=0.025">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder length="${length}" radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 ${-length/2}" rpy="0 0 0"/>
        <material name="grey">
          <color rgba="0.5 0.5 0.5 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${length}" radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 ${-length/2}" rpy="0 0 0"/>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- Base link (fixed) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.04"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Arm links -->
  <xacro:arm_link name="shoulder_pitch_link" length="0.08" radius="0.03"/>
  <xacro:arm_link name="shoulder_roll_link" length="0.14" radius="0.025"/>
  <xacro:arm_link name="elbow_link" length="0.14" radius="0.022"/>
  <xacro:arm_link name="wrist_pitch_link" length="0.10" radius="0.018"/>
  <xacro:arm_link name="wrist_roll_link" length="0.06" radius="0.015"/>

  <!-- End-effector (virtual) -->
  <link name="end_effector_link"/>

  <!--
    Joint chain from kbot URDF (kscalelabs/kbot-models kbot/robot.urdf)
    Origins and axes match kinematics.py:_JOINT_CHAIN exactly.
    Limits from config.yaml converted to radians.
  -->

  <!-- Joint 1: shoulder_pitch (URDF: dof_right_shoulder_pitch_03) -->
  <joint name="shoulder_pitch_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_pitch_link"/>
    <origin xyz="-0.120999 0.002025 0.336659" rpy="0 ${-pi/2} 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.611" upper="3.882" effort="40" velocity="6.28"/>
  </joint>

  <!-- Joint 2: shoulder_roll (URDF: dof_right_shoulder_roll_03) -->
  <joint name="shoulder_roll_joint" type="revolute">
    <parent link="shoulder_pitch_link"/>
    <child link="shoulder_roll_link"/>
    <origin xyz="0 -0.024250 0.080000" rpy="${pi/2} ${pi/2} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.074" upper="0.222" effort="40" velocity="6.28"/>
  </joint>

  <!-- Joint 3: elbow (URDF: dof_right_shoulder_yaw_02) -->
  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_roll_link"/>
    <child link="elbow_link"/>
    <origin xyz="-0.013000 -0.142500 -0.031670" rpy="${-pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.042" upper="3.096" effort="20" velocity="6.28"/>
  </joint>

  <!-- Joint 4: wrist_pitch (URDF: dof_right_elbow_02) -->
  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="elbow_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0.019000 -0.010000 -0.137000" rpy="${-pi/2} 0 ${pi/2}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.042" upper="0.152" effort="6" velocity="6.28"/>
  </joint>

  <!-- Joint 5: wrist_roll (URDF: dof_right_wrist_00) -->
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0.017350 0.103000 0.018000" rpy="${-pi/2} ${pi/2} 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.887" upper="-0.002" effort="6" velocity="6.28"/>
  </joint>

  <!-- End-effector fixed joint -->
  <joint name="end_effector_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ros2_control hardware tags (separate xacro) -->
  <xacro:include filename="$(find steveros_description)/urdf/steveros_ros2_control.xacro"/>

</robot>
